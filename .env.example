# alpha_digest - Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# Google Generative AI API key (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key

# Optional: LangSmith tracing (https://smith.langchain.com/)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=alpha_digest

# Optional: Log to a file (leave empty for console only)
# LOG_FILE=logs/agent.log
